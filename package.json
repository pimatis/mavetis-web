		"@tailwindcss/vite": "^4.1.18",
		"clsx": "^2.1.1",
		"phosphor-svelte": "^3.1.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
