{
	"name": "mavetis-web",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"description": "Official website for Mavetis. Enterprise-grade, local-first Git security scanner with fully offline static analysis, zero telemetry, and zero dependencies.",
	"keywords": [
		"mavetis",
		"git-security",
		"static-analysis",
		"SAST",
		"DevSecOps",
		"security-scanner",
		"OWASP",
		"SARIF",
		"pre-commit-hook",
		"supply-chain-security",
		"regression-detection",
		"enterprise-security",
		"air-gapped-security",
		"CI/CD-security",
		"secrets-detection",
		"code-review",
		"git-hooks",
		"vulnerability-scanner",
		"security-automation",
		"compliance"
	],
	"homepage": "https://mavetis.pimatis.org",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pimatis/mavetis-web.git"
	},
	"bugs": {
		"url": "https://github.com/pimatis/mavetis-web/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Pimatis",
		"url": "https://github.com/pimatis"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
